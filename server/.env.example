# ─── OpenSky Network — OAuth2 Client Credentials ────────────────────────────
# 1. Log in at https://opensky-network.org
# 2. Account → API Clients → Create new client
# 3. Copy client_id and client_secret below
# Token is fetched automatically (30 min TTL, auto-refreshed)
OPENSKY_CLIENT_ID=your_client_id_here
OPENSKY_CLIENT_SECRET=your_client_secret_here

# ─── NASA FIRMS ─────────────────────────────────────────────────────────────
# Get free MAP_KEY at: https://firms.modaps.eosdis.nasa.gov/api/map_key/
NASA_FIRMS_MAP_KEY=your_firms_map_key_here

# ─── Telegram (GramJS) ──────────────────────────────────────────────────────
# Create app at: https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
# After first login, paste the printed session string here to skip re-auth:
TELEGRAM_SESSION=

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3001
